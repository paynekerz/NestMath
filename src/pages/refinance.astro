---
import Base from '../layouts/Base.astro';
import { RefinanceCalculator } from '../components/Refinance/RefinanceCalculator';
---
<Base
  title="NestMath.app — Refinance Break-Even Calculator"
  description="Find out if refinancing is worth it and exactly when you'll break even on closing costs."
  canonical="https://nestmath.app/refinance"
  schemaName="NestMath — Refinance Break-Even Calculator"
  schemaDescription="Calculate the break-even point for refinancing your mortgage based on rate, term, and closing costs."
>
  <div class="max-w-5xl mx-auto px-4 pt-8 pb-2">
    <h1 class="text-2xl font-bold">Refinance Break-Even Calculator</h1>
    <p class="text-muted mt-1 text-sm">See exactly how long it takes to recoup your closing costs — and whether refinancing makes financial sense before you move.</p>
  </div>
  <RefinanceCalculator client:load />
</Base>
