---
import Base from '../layouts/Base.astro';
import { SavingsPlannerCalculator } from '../components/SavingsPlanner/SavingsPlannerCalculator';
---
<Base
  title="NestMath.app — Down Payment Savings Planner"
  description="Find out exactly how long it takes to save for a down payment. Enter your target price, savings rate, and return on savings — see the month you'll be ready to buy."
  canonical="https://nestmath.app/savings-planner"
  schemaName="NestMath — Down Payment Savings Planner"
  schemaDescription="Calculate how long it takes to save for a down payment and closing costs based on your monthly savings rate and investment return."
  breadcrumbTool="Savings Planner"
>
  <div class="max-w-5xl mx-auto px-4 pt-8 pb-2">
    <h1 class="text-2xl font-bold">Down Payment Savings Planner</h1>
    <p class="text-muted mt-1 text-sm">See exactly how long it takes to save your down payment — and how much your returns add up along the way.</p>
  </div>
  <SavingsPlannerCalculator client:load />
</Base>
