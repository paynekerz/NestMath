---
import Base from '../layouts/Base.astro';
---
<Base
  title="Something went wrong — NestMath"
  description="NestMath is temporarily unavailable. We'll be back shortly."
  canonical="https://nestmath.app/500"
>
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center gap-6">
    <span class="material-symbols-outlined text-6xl text-on-surface-variant" aria-hidden="true">construction</span>
    <div class="flex flex-col gap-2">
      <h1 id="error-heading" class="text-display font-bold text-on-surface">Pardon our dust</h1>
      <p id="error-subtext" class="text-body-lg text-on-surface-variant max-w-md">
        We're doing some maintenance. The site will be back up shortly — thanks for your patience.
      </p>
    </div>
    <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-on-primary text-label-lg font-semibold hover:opacity-90 transition-opacity">
      <span class="material-symbols-outlined text-[18px]" aria-hidden="true">home</span>
      Go back home
    </a>
  </div>

  <script>
    const referrer = document.referrer;
    if (referrer && !referrer.includes(location.origin + '/')) {
      // came from within the site but hit a 500 on a tool page
    }
    try {
      const origin = location.origin;
      if (referrer && referrer.startsWith(origin) && referrer !== origin + '/') {
        const heading = document.getElementById('error-heading');
        const subtext = document.getElementById('error-subtext');
        if (heading) heading.textContent = 'Something went wrong';
        if (subtext) subtext.textContent = "We hit an unexpected error on this page. Try refreshing, or head back home — we'll have it fixed soon.";
      }
    } catch (_) {}
  </script>
</Base>
