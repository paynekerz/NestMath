---
import Base from '../layouts/Base.astro';
---

<Base
  title="About NestMath — Free & Open Source Financial Planning"
  description="NestMath is a free, open source financial toolkit. No paywalls, no account, no data collected. Learn why we built it and how it works."
  canonical="https://nestmath.app/about"
  schemaName="NestMath — About"
  schemaDescription="Free and open source financial planning tools for everyone. No account. Your data stays on your device."
>
  <div class="relative overflow-hidden">
    <div
      class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-primary-accent/20 blur-[120px] pointer-events-none -translate-y-1/4 translate-x-1/4"
      aria-hidden="true"
    ></div>

    <div class="max-w-[768px] mx-auto px-[24px] py-[64px]">

      <!-- Header -->
      <div class="animate-reveal mb-[64px]">
        <div class="inline-flex items-center gap-[8px] rounded-full bg-primary-container/10 border border-primary/20 px-[16px] py-[8px] mb-[32px]">
          <span class="w-2 h-2 rounded-full bg-success-emerald animate-pulse-dot" aria-hidden="true"></span>
          <span class="text-label-sm text-primary">Free &amp; Open Source</span>
        </div>
        <h1 class="text-headline-xl font-bold text-on-surface leading-tight -tracking-[0.02em] mb-[24px]">
          Financial freedom shouldn't come with a subscription.
        </h1>
        <p class="text-body-lg text-on-surface-variant leading-relaxed">
          NestMath is a free, open-source toolkit for personal financial decisions. No account. No cost. Nothing tracked.
        </p>
      </div>

      <!-- Origin story -->
      <section class="animate-reveal stagger-1 mb-[48px]">
        <h2 class="text-headline-md font-semibold text-on-surface mb-[16px]">How it started</h2>
        <div class="prose-surface space-y-[16px]">
          <p class="text-body-md text-on-surface-variant leading-relaxed">
            NestMath started as a buy vs. rent calculator I built to understand the real math behind buying a home. The useful tools I found were either behind paywalls, buried in ads, or missing entirely.
          </p>
          <p class="text-body-md text-on-surface-variant leading-relaxed">
            One calculator turned into many. The common thread: people making big financial decisions should be able to run the numbers themselves, without a subscription or an advisor.
          </p>
        </div>
      </section>

      <!-- Mission callout -->
      <section class="animate-reveal stagger-2 mb-[48px]">
        <div class="rounded-xl border border-primary/20 bg-primary-container/10 px-[32px] py-[28px]">
          <p class="text-label-sm font-semibold text-primary uppercase tracking-widest mb-[12px]">Mission</p>
          <p class="text-headline-md font-semibold text-on-surface leading-snug">
            Financial freedom and education should never be behind a paywall.
          </p>
        </div>
      </section>

      <!-- What NestMath is -->
      <section class="animate-reveal stagger-2 mb-[48px]">
        <h2 class="text-headline-md font-semibold text-on-surface mb-[16px]">What it is</h2>
        <p class="text-body-md text-on-surface-variant leading-relaxed mb-[24px]">
          NestMath covers the financial decisions most people face: buying a home, paying off debt, understanding take-home pay, and planning savings. The tools work for individuals, households, and classrooms.
        </p>

        <div class="grid sm:grid-cols-3 gap-[16px]">
          <div class="rounded-xl border border-border-subtle bg-surface-container-low p-[20px]">
            <span class="material-symbols-outlined text-primary text-[24px] mb-[8px]" aria-hidden="true">lock_open</span>
            <p class="text-label-md font-semibold text-on-surface mb-[4px]">Always free</p>
            <p class="text-label-sm text-on-surface-variant">No plan, no trial, no credit card.</p>
          </div>
          <div class="rounded-xl border border-border-subtle bg-surface-container-low p-[20px]">
            <span class="material-symbols-outlined text-primary text-[24px] mb-[8px]" aria-hidden="true">code</span>
            <p class="text-label-md font-semibold text-on-surface mb-[4px]">Open source</p>
            <p class="text-label-sm text-on-surface-variant">Every line of code is public on GitHub.</p>
          </div>
          <div class="rounded-xl border border-border-subtle bg-surface-container-low p-[20px]">
            <span class="material-symbols-outlined text-primary text-[24px] mb-[8px]" aria-hidden="true">security</span>
            <p class="text-label-md font-semibold text-on-surface mb-[4px]">Private by design</p>
            <p class="text-label-sm text-on-surface-variant">Your numbers never leave your browser.</p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="animate-reveal stagger-3 mb-[64px]">
        <h2 class="text-headline-md font-semibold text-on-surface mb-[24px]">Common questions</h2>

        <div class="flex flex-col gap-[8px]">

          <details class="faq-item rounded-xl border border-border-subtle bg-surface-elevated">
            <summary class="cursor-pointer list-none flex items-center justify-between px-[24px] py-[16px] text-body-sm font-medium text-on-surface select-none hover:bg-surface-container-high/30 transition-colors rounded-xl">
              Do you collect any data?
              <span class="faq-chevron material-symbols-outlined text-on-surface-variant text-[16px] ml-[8px] shrink-0 transition-transform duration-300 ease-in-out" aria-hidden="true">expand_more</span>
            </summary>
            <div class="grid transition-[grid-template-rows] duration-300 ease-in-out" style="grid-template-rows: 0fr">
              <div class="overflow-hidden">
                <p class="px-[24px] pb-[24px] pt-[8px] text-body-sm text-on-surface-variant leading-relaxed border-t border-border-subtle">
                  No. Everything you enter stays in your browser. Nothing goes to a server, gets logged, or leaves your device. No analytics, no cookies, no account system.
                </p>
              </div>
            </div>
          </details>

          <details class="faq-item rounded-xl border border-border-subtle bg-surface-elevated">
            <summary class="cursor-pointer list-none flex items-center justify-between px-[24px] py-[16px] text-body-sm font-medium text-on-surface select-none hover:bg-surface-container-high/30 transition-colors rounded-xl">
              Is this really free?
              <span class="faq-chevron material-symbols-outlined text-on-surface-variant text-[16px] ml-[8px] shrink-0 transition-transform duration-300 ease-in-out" aria-hidden="true">expand_more</span>
            </summary>
            <div class="grid transition-[grid-template-rows] duration-300 ease-in-out" style="grid-template-rows: 0fr">
              <div class="overflow-hidden">
                <p class="px-[24px] pb-[24px] pt-[8px] text-body-sm text-on-surface-variant leading-relaxed border-t border-border-subtle">
                  Yes. NestMath runs on voluntary donations through Ko-fi. If it's useful, a coffee helps keep it running and adds more tools. Entirely optional.
                </p>
              </div>
            </div>
          </details>

          <details class="faq-item rounded-xl border border-border-subtle bg-surface-elevated">
            <summary class="cursor-pointer list-none flex items-center justify-between px-[24px] py-[16px] text-body-sm font-medium text-on-surface select-none hover:bg-surface-container-high/30 transition-colors rounded-xl">
              Can I use this in a classroom or financial literacy program?
              <span class="faq-chevron material-symbols-outlined text-on-surface-variant text-[16px] ml-[8px] shrink-0 transition-transform duration-300 ease-in-out" aria-hidden="true">expand_more</span>
            </summary>
            <div class="grid transition-[grid-template-rows] duration-300 ease-in-out" style="grid-template-rows: 0fr">
              <div class="overflow-hidden">
                <p class="px-[24px] pb-[24px] pt-[8px] text-body-sm text-on-surface-variant leading-relaxed border-t border-border-subtle">
                  Yes, that's exactly what it's built for. Share it freely. No attribution required, no license to worry about.
                </p>
              </div>
            </div>
          </details>

          <details class="faq-item rounded-xl border border-border-subtle bg-surface-elevated">
            <summary class="cursor-pointer list-none flex items-center justify-between px-[24px] py-[16px] text-body-sm font-medium text-on-surface select-none hover:bg-surface-container-high/30 transition-colors rounded-xl">
              Who built this?
              <span class="faq-chevron material-symbols-outlined text-on-surface-variant text-[16px] ml-[8px] shrink-0 transition-transform duration-300 ease-in-out" aria-hidden="true">expand_more</span>
            </summary>
            <div class="grid transition-[grid-template-rows] duration-300 ease-in-out" style="grid-template-rows: 0fr">
              <div class="overflow-hidden">
                <p class="px-[24px] pb-[24px] pt-[8px] text-body-sm text-on-surface-variant leading-relaxed border-t border-border-subtle">
                  NestMath is built and maintained by me, Payne Kerz. I'm a software engineer by trade. It's a personal open source project, no company, no team, no VC money.
                </p>
              </div>
            </div>
          </details>

        </div>

        <script>
          document.querySelectorAll('details.faq-item').forEach(details => {
            const summary = details.querySelector('summary');
            const grid = details.querySelector(':scope > div');
            const chevron = summary?.querySelector('.faq-chevron');
            summary?.addEventListener('click', e => {
              e.preventDefault();
              const isOpen = details.open;
              if (!isOpen) {
                details.open = true;
                requestAnimationFrame(() => {
                  grid.style.gridTemplateRows = '1fr';
                  chevron?.classList.add('rotate-180');
                });
              } else {
                grid.style.gridTemplateRows = '0fr';
                chevron?.classList.remove('rotate-180');
                grid.addEventListener('transitionend', () => { details.open = false; }, { once: true });
              }
            });
          });
        </script>
      </section>

      <!-- CTA -->
      <section class="animate-reveal stagger-4 rounded-xl border border-border-subtle bg-surface-container-low p-[32px] text-center">
        <p class="text-body-md text-on-surface-variant mb-[20px]">
          If NestMath saved you time or helped you make a decision, a coffee goes a long way toward keeping it running.
        </p>
        <div class="flex flex-wrap justify-center gap-[12px]">
          <a
            href="https://ko-fi.com/paynekerz"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[8px] bg-primary-accent text-white px-[24px] py-[12px] rounded-lg text-label-md font-semibold hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary-accent/20"
          >
            <span class="material-symbols-outlined text-[18px]" aria-hidden="true">coffee</span>
            Support on Ko-fi
          </a>
          <a
            href="https://github.com/paynekerz/NestMath"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[8px] border border-border-subtle bg-surface px-[24px] py-[12px] rounded-lg text-label-md font-semibold text-on-surface hover:border-primary-accent/50 transition-all"
          >
            <span class="material-symbols-outlined text-[18px]" aria-hidden="true">code</span>
            View on GitHub
          </a>
        </div>
      </section>

    </div>
  </div>
</Base>
