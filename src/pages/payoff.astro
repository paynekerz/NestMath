---
import Base from '../layouts/Base.astro';
import { PayoffCalculator } from '../components/Payoff/PayoffCalculator';
---
<Base
  title="NestMath.app — Mortgage Payoff Calculator"
  description="See how much extra payments save — and how fast they pay off your loan. Free calculator, no account required."
  canonical="https://nestmath.app/payoff"
  schemaName="NestMath — Mortgage Payoff Calculator"
  schemaDescription="Calculate how extra monthly payments or a lump sum reduce your mortgage payoff date and total interest paid."
  breadcrumbTool="Payoff"
>
  <div class="max-w-5xl mx-auto px-4 pt-8 pb-2">
    <h1 class="text-2xl font-bold">Mortgage Payoff Calculator</h1>
    <p class="text-muted mt-1 text-sm">See how extra payments cut your payoff date and total interest paid.</p>
  </div>
  <PayoffCalculator client:load />
</Base>
