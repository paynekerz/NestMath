---
import '../styles/global.css';
import interFont from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import { Nav } from '../components/ui/Nav';
import { Breadcrumb } from '../components/ui/Breadcrumb';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schemaName?: string;
  schemaDescription?: string;
  breadcrumbTool?: string;
  faqItems?: { q: string; a: string }[];
}

const {
  title,
  description,
  canonical,
  schemaName = 'NestMath',
  schemaDescription = description,
  breadcrumbTool,
  faqItems,
} = Astro.props;

const currentPath = Astro.url.pathname;
const SITE_URL = 'https://nestmath.app';
const canonicalUrl = canonical ?? `${SITE_URL}${currentPath}`;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: schemaName,
  url: canonicalUrl,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});

// Global identity schemas — emitted on every page.
const identitySchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'NestMath',
    url: SITE_URL,
    description: 'Free personal finance calculators for home buying, debt payoff, and investing decisions.',
    sameAs: ['https://www.linkedin.com/in/paynekerz'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'NestMath',
    url: SITE_URL,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'NestMath',
    url: SITE_URL,
    description: 'Free personal finance calculators. No account required.',
    priceRange: 'Free',
  },
]);

// Per-page FAQ schema, built from the same items the page renders.
const faqSchema = faqItems && faqItems.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a.replace(/<[^>]+>/g, '') },
      })),
    })
  : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.dataset.theme = t;
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" as="font" href={interFont} type="font/woff2" crossorigin />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" title="NestMath" />
    <script type="application/ld+json" set:html={schema} />
    <script type="application/ld+json" set:html={identitySchema} />
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
    <Analytics />
  </head>
  <body>
    <div class="blueprint-grid absolute inset-x-0 top-0 h-[420px] pointer-events-none opacity-60" aria-hidden="true" data-print="hide"></div>
    <Nav currentPath={currentPath} client:idle />
    {breadcrumbTool && <Breadcrumb tool={breadcrumbTool} />}
    <main>
      <slot />
    </main>
    <footer data-print="hide" class="mt-auto border-t border-border-subtle">
      <div class="max-w-[1280px] mx-auto px-4 py-6 flex flex-col items-center gap-3 text-center">
        <p class="text-label-sm text-on-surface-variant/80 max-w-[640px] leading-relaxed">
          NestMath provides estimates for educational and informational purposes only. It is not financial,
          tax, investment, or legal advice. Figures are projections based on the assumptions you enter and
          may use tax or rate values that change over time. Verify any decision with a qualified professional.
          Provided without warranty of any kind.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-body-sm text-on-surface-variant">
          <a href="/privacy" class="text-primary hover:underline">Privacy</a>
          <span aria-hidden="true">·</span>
          <a href="/terms" class="text-primary hover:underline">Terms</a>
          <span aria-hidden="true">·</span>
          <a href="https://ko-fi.com/paynekerz" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Support on Ko-fi</a>
          <span aria-hidden="true">·</span>
          <a href="https://github.com/paynekerz/NestMath" target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.linkedin.com/in/paynekerz" target="_blank" rel="noopener" class="text-primary hover:underline">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.flaticon.com/free-icons/furniture-and-household" title="furniture and household icons created by Grafixpoint - Flaticon" target="_blank" rel="noopener" class="text-primary hover:underline">Icons by Grafixpoint</a>
        </div>
        <p class="text-label-sm text-on-surface-variant/70">
          © {new Date().getFullYear()} ArcLayer LLC · <span data-portfolio-link>Built by Payne Kerz</span>
        </p>
      </div>
    </footer>
  </body>
</html>
