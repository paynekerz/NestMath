---
import '../styles/global.css';
import { KofiButton } from '../components/ui/KofiButton';
import { Nav } from '../components/ui/Nav';
import { BottomNav } from '../components/ui/BottomNav';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schemaName?: string;
  schemaDescription?: string;
}

const {
  title,
  description,
  canonical,
  schemaName = 'NestMath',
  schemaDescription = description,
} = Astro.props;

const currentPath = Astro.url.pathname;
const SITE_URL = 'https://nestmath.app';
const canonicalUrl = canonical ?? `${SITE_URL}${currentPath}`;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: schemaName,
  url: canonicalUrl,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={schema} />
  </head>
  <body>
<Nav currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer data-print="hide" class="flex items-center justify-center gap-3 py-6 text-body-sm text-on-surface-variant border-t border-border-subtle mt-auto">
      <KofiButton />
      <span aria-hidden="true">·</span>
      <!-- TODO: replace href with nestmath GitHub repo URL once created -->
      <a href="#" class="text-primary hover:underline">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.flaticon.com/free-icons/furniture-and-household" title="furniture and household icons created by Grafixpoint - Flaticon" target="_blank" rel="noopener" class="text-primary hover:underline">Icons by Grafixpoint</a>
      <span aria-hidden="true">·</span>
      <span data-portfolio-link>Made by Payne Kerz</span>
    </footer>
    <BottomNav client:load />
  </body>
</html>
