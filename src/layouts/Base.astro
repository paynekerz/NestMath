---
import '../styles/global.css';
import interFont from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import { Nav } from '../components/ui/Nav';
import { Breadcrumb } from '../components/ui/Breadcrumb';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schemaName?: string;
  schemaDescription?: string;
  breadcrumbTool?: string;
}

const {
  title,
  description,
  canonical,
  schemaName = 'NestMath',
  schemaDescription = description,
  breadcrumbTool,
} = Astro.props;

const currentPath = Astro.url.pathname;
const SITE_URL = 'https://nestmath.app';
const canonicalUrl = canonical ?? `${SITE_URL}${currentPath}`;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: schemaName,
  url: canonicalUrl,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.dataset.theme = t;
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" as="font" href={interFont} type="font/woff2" crossorigin />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={schema} />
    <Analytics />
  </head>
  <body>
    <Nav currentPath={currentPath} client:idle />
    {breadcrumbTool && <Breadcrumb tool={breadcrumbTool} />}
    <main>
      <slot />
    </main>
    <footer data-print="hide" class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 px-4 py-6 text-body-sm text-on-surface-variant border-t border-border-subtle mt-auto">
      <a href="https://ko-fi.com/paynekerz" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Support on Ko-fi</a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/paynekerz/NestMath" target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.flaticon.com/free-icons/furniture-and-household" title="furniture and household icons created by Grafixpoint - Flaticon" target="_blank" rel="noopener" class="text-primary hover:underline">Icons by Grafixpoint</a>
      <span aria-hidden="true">·</span>
      <span data-portfolio-link>Made by Payne Kerz</span>
    </footer>
  </body>
</html>
