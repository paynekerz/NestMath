---
import '../styles/global.css';
import { KofiButton } from '../components/ui/KofiButton';
import { Nav } from '../components/ui/Nav';
import { BottomNav } from '../components/ui/BottomNav';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schemaName?: string;
  schemaDescription?: string;
}

const {
  title,
  description,
  canonical,
  schemaName = 'NestMath',
  schemaDescription = description,
} = Astro.props;

const currentPath = Astro.url.pathname;
const SITE_URL = 'https://nestmath.app';
const canonicalUrl = canonical ?? `${SITE_URL}${currentPath}`;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: schemaName,
  url: canonicalUrl,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='4' y='15' width='24' height='15' fill='%235E6AF6'/%3E%3Cpolygon points='16,3 2,16 30,16' fill='%234252E0'/%3E%3Crect x='12' y='20' width='8' height='10' rx='1' fill='white' opacity='.88'/%3E%3C/svg%3E" />
    <script type="application/ld+json" set:html={schema} />
  </head>
  <body>
<Nav currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer data-print="hide" class="flex items-center justify-center gap-3 py-6 text-body-sm text-on-surface-variant border-t border-border-subtle mt-auto">
      <KofiButton />
      <span aria-hidden="true">·</span>
      <!-- TODO: replace href with nestmath GitHub repo URL once created -->
      <a href="#" class="text-primary hover:underline">GitHub</a>
      <span aria-hidden="true">·</span>
      <span data-portfolio-link>Made by Payne Kerz</span>
    </footer>
    <BottomNav client:load />
  </body>
</html>
